# -------------------------------------------------------------------
# Copia este archivo como .env  ->  cp .env.example .env
# Luego reemplaza los valores por los tuyos.
# El archivo .env NO se sube a GitHub (esta en .gitignore).
# -------------------------------------------------------------------

# Puerto donde corre el servidor
PORT=3000

# Cadena de conexion a MongoDB (Atlas o local)
MONGODB_URI=pon_aqui_tu_cadena_de_conexion

# Secreto para firmar los tokens JWT (usa una cadena larga y aleatoria)
# IMPORTANTE: solo letras y numeros. Los caracteres especiales (# % & etc.)
# se truncan al leer el archivo .env y el token queda firmado con un
# secreto distinto al que crees.
JWT_SECRET=pon_aqui_un_secreto_largo_y_alfanumerico

# Cuanto dura un token antes de expirar (ej: 1d, 12h, 30m)
JWT_EXPIRES_IN=1d

# Datos del primer usuario admin, usados por scripts/createAdmin.js
# (node scripts/createAdmin.js). No es una ruta de la API, se corre a mano
# desde la terminal cuando haga falta un admin nuevo.
ADMIN_EMAIL=pon_aqui_el_email_del_admin
ADMIN_PASSWORD=pon_aqui_una_contrasena_segura
ADMIN_NOMBRE=pon_aqui_el_nombre_del_admin
