# -------------------------------------------------------------------
# Copia este archivo como .env  ->  cp .env.example .env
# Luego reemplaza los valores por los tuyos.
# El archivo .env NO se sube a GitHub (esta en .gitignore).
# -------------------------------------------------------------------

# Puerto donde corre el servidor
PORT=3000

# Cadena de conexion a MongoDB (Atlas o local)
MONGODB_URI=pon_aqui_tu_cadena_de_conexion

# Secreto para firmar los tokens JWT (usa una cadena larga y aleatoria)
JWT_SECRET=pon_aqui_un_secreto_largo_y_aleatorio

# Cuanto dura un token antes de expirar (ej: 1d, 12h, 30m)
JWT_EXPIRES_IN=1d
